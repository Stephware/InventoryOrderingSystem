<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Ordering System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/sweetalert2/sweetalert2.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Inventory System</a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="Index">Orders</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Product" asp-action="Index">Products</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Index">Customers</a>
                            </li>
                        }
                        else if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="Index">My Orders</a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-danger"
                               onclick="return confirm('Logout?')"
                               asp-controller="Account"
                               asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <footer class="border-top text-muted mt-5 py-3 text-center">
        <small>&copy; 2026 - Inventory Ordering System</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            @if (TempData["LoginSuccess"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: '@TempData["LoginSuccess"]'
                        });
                    </text>
            }

            @if (TempData["LogoutSuccess"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Logged out',
                            text: '@TempData["LogoutSuccess"]'
                        });
                    </text>
            }

            @if (TempData["Success"] != null)
            {
                    <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: '@TempData["Success"]'
                        });
                    </text>
            }

            @if (TempData["Error"] != null)
            {
                <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: '@TempData["Error"]'
                    });
                </text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>