    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Ordering System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/sweetalert2/sweetalert2.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

        <!-- LEFT SIDE -->
        <ul class="navbar-nav flex-grow-1">

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                if (User.IsInRole("Admin"))
                {
                    <li><a class="nav-link" asp-controller="Order">Orders</a></li>
                    <li><a class="nav-link" asp-controller="Product">Products</a></li>
                    <li><a class="nav-link" asp-controller="Customer">Customers</a></li>
                }
                else if (User.IsInRole("Customer"))
                {
                    <li><a class="nav-link" asp-controller="Order">My Orders</a></li>
                }
            }
            else
            {
                <li><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                <li><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
            }
        </ul>

        <!-- RIGHT SIDE -->
        <ul class="navbar-nav">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <li class="nav-item">
                    <a class="nav-link text-danger"
                       onclick="return confirm('Are you sure you want to logout?')"
                       asp-controller="Account"
                       asp-action="Logout">
                        Logout
                    </a>
                </li>
            }
        </ul>

    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container">
            &copy; 2026 - Inventory Ordering System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>