@model IEnumerable<InventoryOrderingSystem.Models.Database.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Inventory Management</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Product</a>
</div>

<table class="table table-striped table-hover border align-middle">
    <thead class="table-dark">
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Update Price</th>
            <th>Update Stock</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <tr>
                    <td><strong>@product.ProductCode</strong></td>
                    <td>@product.ProductName</td>
                    <td>@product.Price.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                    <td>
                        <span class="badge @(product.Stock > 0 ? "bg-success" : "bg-danger") fs-6">
                            @product.Stock
                        </span>
                    </td>
                    <td>
                        <form asp-action="UpdatePrice" method="post" class="d-flex">
                            <input type="hidden" name="id" value="@product.ProductId" />
                            <input type="number" step="0.01" name="price" value="@product.Price" class="form-control form-control-sm me-2" style="width: 100px;" required />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="UpdateStock" method="post" class="d-flex">
                            <input type="hidden" name="id" value="@product.ProductId" />
                            <input type="number" name="stock" value="@product.Stock" class="form-control form-control-sm me-2" style="width: 80px;" required />
                            <button type="submit" class="btn btn-sm btn-outline-success">Update</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No products found.</td>
            </tr>
        }
    </tbody>
</table>