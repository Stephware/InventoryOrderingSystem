@model IEnumerable<InventoryOrderingSystem.Models.Database.Product>

@{
    ViewData["Title"] = "Products";

    int totalItems = ViewBag.TotalItems ?? 0;
    int currentPage = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    string search = ViewBag.Search as string;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Inventory Management</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Product</a>
</div>

<form method="get" asp-action="Index" class="mb-3 d-flex gap-2 w-50">
    <input type="text" name="search" value="@search" class="form-control" placeholder="Search products..." />
    <button type="submit" class="btn btn-secondary">Search</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
</form>

<table class="table table-striped table-hover border align-middle">
    <thead class="table-dark">
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Update Price</th>
            <th>Update Stock</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <tr>
                    <td><strong>@product.ProductCode</strong></td>
                    <td>@product.ProductName</td>
                    <td>@product.Price.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                    <td>
                        <span class="badge @(product.Stock > 0 ? "bg-success" : "bg-danger") fs-6">
                            @product.Stock
                        </span>
                    </td>
                    <td>
                        <form asp-action="UpdatePrice" method="post" class="d-flex">
                            <input type="hidden" name="id" value="@product.ProductId" />
                            <input type="number" step="0.01" name="price" value="@product.Price" class="form-control form-control-sm me-2" style="width: 100px;" required />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="UpdateStock" method="post" class="d-flex">
                            <input type="hidden" name="id" value="@product.ProductId" />
                            <input type="number" name="stock" value="@product.Stock" class="form-control form-control-sm me-2" style="width: 80px;" required />
                            <button type="submit" class="btn btn-sm btn-outline-success">Update</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No products found.</td>
            </tr>
        }

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    </tbody>
</table>

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-4">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@search" aria-label="Previous">
                    <span aria-hidden="true">&lt;</span>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@search" aria-label="Next">
                    <span aria-hidden="true">&gt;</span>
                </a>
            </li>

        </ul>
    </nav>
}