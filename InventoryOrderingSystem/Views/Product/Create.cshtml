@model InventoryOrderingSystem.Models.Database.Product

@{
    ViewData["Title"] = "Add Product";
}

<h2>Add New Product</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label>Product Code</label>
        <input asp-for="ProductCode" class="form-control" required />
        <span asp-validation-for="ProductCode" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Product Name</label>
        <input asp-for="ProductName" class="form-control" required />
        <span asp-validation-for="ProductName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Price</label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" required />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Stock</label>
        <input asp-for="Stock" type="number" class="form-control" required />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Add Product</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}