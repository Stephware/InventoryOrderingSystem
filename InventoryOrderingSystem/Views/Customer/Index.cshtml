@model IEnumerable<InventoryOrderingSystem.Models.Database.Customer>

@{
    ViewData["Title"] = "Customers";

    int totalItems = ViewBag.TotalItems ?? 0;
    int currentPage = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    string search = ViewBag.Search as string;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Customer Management</h2>

    <a asp-controller="Account"
       asp-action="Register"
       class="btn btn-primary">
        Add New Customer
    </a>
</div>

<form method="get" asp-action="Index" class="mb-3 d-flex gap-2 w-50">
    <input type="text" name="search" value="@search" class="form-control" placeholder="Search customers..." />
    <button type="submit" class="btn btn-secondary">Search</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
</form>

<table class="table table-striped table-hover border align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Username</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var customer in Model)
            {
                <tr>
                    <td>@customer.CustomerId</td>
                    <td>@customer.Username</td>

                    <td>@customer.FirstName</td>
                    <td>@customer.LastName</td>

                    <td>
                        @if (customer.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>

                    <td>
                        <form asp-action="ToggleStatus"
                              method="post"
                              style="display:inline;">

                            <input type="hidden"
                                   name="id"
                                   value="@customer.CustomerId" />

                            @if (customer.IsActive)
                            {
                                <button class="btn btn-danger btn-sm"
                                        onclick="return confirm('Deactivate this customer?')">
                                    Deactivate
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-success btn-sm"
                                        onclick="return confirm('Activate this customer?')">
                                    Activate
                                </button>
                            }
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No customers found.
                </td>
            </tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-4">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@search" aria-label="Previous">
                    <span aria-hidden="true">&lt;</span>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@search" aria-label="Next">
                    <span aria-hidden="true">&gt;</span>
                </a>
            </li>

        </ul>
    </nav>
}