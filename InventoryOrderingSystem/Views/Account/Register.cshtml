@model RegistrationModel

@{
    ViewData["Title"] = "Register";
}

<div class="d-flex justify-content-center align-items-center" style="height:90vh;">
    <div class="card shadow-sm p-4" style="width: 400px;">
        <h4 class="text-center mb-3">Register</h4>

        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger small" })

            <div class="mb-2">
                @Html.LabelFor(x => x.Username)
                @Html.TextBoxFor(x => x.Username, new { @class = "form-control" })
                @Html.ValidationMessageFor(x => x.Username, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-2">
                @Html.LabelFor(x => x.FirstName)
                @Html.TextBoxFor(x => x.FirstName, new { @class = "form-control" })
            </div>

            <div class="mb-2">
                @Html.LabelFor(x => x.LastName)
                @Html.TextBoxFor(x => x.LastName, new { @class = "form-control" })
            </div>

            <div class="mb-2">
                @Html.LabelFor(x => x.Password)
                @Html.PasswordFor(x => x.Password, new { @class = "form-control" })
                @Html.ValidationMessageFor(x => x.Password, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(x => x.ConfirmPassword)
                @Html.PasswordFor(x => x.ConfirmPassword, new { @class = "form-control" })

                @Html.ValidationMessageFor(x => x.ConfirmPassword, "", new { @class = "text-danger small" })
            </div>

            <button class="btn btn-success w-100">Register</button>
        }

        <div class="text-center mt-3">
            <small>Already have an account? <a asp-action="Login">Login</a></small>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["Error"] != null)
        {
                <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: '@TempData["Error"]'
                    });
                </text>
        }
    </script>
}