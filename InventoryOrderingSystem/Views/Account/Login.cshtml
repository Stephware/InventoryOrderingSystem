@model InventoryOrderingSystem.Models.AdminLoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="d-flex justify-content-center align-items-center" style="height:80vh;">
    <div class="card shadow-sm p-4" style="width: 350px;">
        <h4 class="text-center mb-3">Login</h4>

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            @Html.ValidationSummary(true, "", new { @class = "text-danger small" })

            <div class="mb-3">
                @Html.LabelFor(x => x.Username)
                @Html.TextBoxFor(x => x.Username, new { @class = "form-control" })
                @Html.ValidationMessageFor(x => x.Username, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(x => x.Password)
                @Html.PasswordFor(x => x.Password, new { @class = "form-control" })
                @Html.ValidationMessageFor(x => x.Password, "", new { @class = "text-danger small" })
            </div>

            <button class="btn btn-primary w-100">Login</button>
        }

        <div class="text-center mt-3">
            <small>No account? <a asp-action="Register">Register</a></small>
        </div>

        @section Scripts{
            <script>
                @if (TempData["Error"] != null)
                {
                        <text>
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: '@TempData["Error"]'
                            });
                        </text>
                }
            </script>
        }
    </div>
</div>