@model InventoryOrderingSystem.Models.Database.Order

@{
    ViewData["Title"] = "Edit Order";
}

<h2>Edit Order</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" name="orderId" value="@Model.OrderId" />

    <h5>Modify Products</h5>

    @for (int i = 0; i < Model.OrderItems.Count; i++)
    {
        <div class="row mb-2">
            <div class="col-5">
                <input type="hidden" name="items[@i].ProductId" value="@Model.OrderItems.ElementAt(i).ProductId" />
                <label>@Model.OrderItems.ElementAt(i).Product?.ProductName</label>
            </div>

            <div class="col-3">
                <input type="number"
                       name="items[@i].Quantity"
                       value="@Model.OrderItems.ElementAt(i).Quantity"
                       class="form-control"
                       min="0" />
            </div>
        </div>
    }

    <button class="btn btn-success mt-3">Update Order</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>