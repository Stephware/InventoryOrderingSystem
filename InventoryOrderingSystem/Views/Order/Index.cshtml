@model IEnumerable<InventoryOrderingSystem.Models.Database.Order>

@{
    ViewData["Title"] = "Orders";

    int totalItems = ViewBag.TotalItems ?? 0;
    int currentPage = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    string search = ViewBag.Search as string;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Orders</h2>

    @if (User.IsInRole("Admin") || User.IsInRole("Customer"))
    {
        <a asp-action="Create" class="btn btn-primary">Create Order</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form method="get" asp-action="Index" class="mb-3 d-flex gap-2 w-50">
    <input type="text" name="search" value="@search" class="form-control" placeholder="Search by Order ID or Status..." />
    <button type="submit" class="btn btn-secondary">Search</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
</form>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Status</th>
            <th>Customer</th>
            <th>Total Amount</th>
            <th>Date Created</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var order in Model)
            {
                <tr>
                    <td>
                        @if (order.Status == "Completed")
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else if (order.Status == "Cancelled")
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>

                    <td>@order.Customer?.Username</td>

                    <td>@order.TotalAmount.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>

                    <td>@order.DateCreated.ToString("yyyy-MM-dd HH:mm")</td>

                    <td>
                        <a asp-action="Details"
                           asp-route-id="@order.OrderId"
                           class="btn btn-sm btn-info">
                            View
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            @if (order.Status == "Pending")
                            {
                                <form asp-action="MarkCompleted"
                                      method="post"
                                      style="display:inline;">
                                    <input type="hidden"
                                           name="id"
                                           value="@order.OrderId" />
                                    <button class="btn btn-success btn-sm"
                                            onclick="return confirm('Mark this order as completed?')">
                                        Complete
                                    </button>
                                </form>
                            }

                            <a asp-action="Edit"
                               asp-route-id="@order.OrderId"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            @if (order.Status != "Cancelled")
                            {
                                <form asp-action="Cancel"
                                      method="post"
                                      style="display:inline;">
                                    <input type="hidden"
                                           name="id"
                                           value="@order.OrderId" />
                                    <button class="btn btn-danger btn-sm"
                                            onclick="return confirm('Cancel this order?')">
                                        Cancel
                                    </button>
                                </form>
                            }
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    No orders found.
                </td>
            </tr>
        }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-4">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@search" aria-label="Previous">
                    <span aria-hidden="true">&lt;</span>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@search" aria-label="Next">
                    <span aria-hidden="true">&gt;</span>
                </a>
            </li>

        </ul>
    </nav>
}