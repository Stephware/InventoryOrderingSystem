@*

*@
@{
    var isAdmin = User.IsInRole("Admin");
}

<form asp-action="Create" method="post">

    <!-- ADMIN ONLY: SELECT CUSTOMER -->
    @if (isAdmin)
    {
        <div class="form-group mb-3">
            <label>Select Customer</label>
            <select name="CustomerId" class="form-control" required>
                <option value="">-- Select Customer --</option>
                @foreach (var c in ViewBag.Customers)
                {
                    <option value="@c.CustomerId">
                        @c.Username (@(c.IsActive ? "Active" : "Inactive"))
                    </option>
                }
            </select>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You are placing an order under your account.
        </div>
    }

    <!-- PRODUCTS -->
    <h5>Products</h5>

    @for (int i = 0; i < ((List<InventoryOrderingSystem.Models.Database.Product>)ViewBag.Products).Count; i++)
    {
        var product = ((List<InventoryOrderingSystem.Models.Database.Product>)ViewBag.Products)[i];

        <div class="row mb-2">
            <div class="col-5">
                <input type="hidden" name="Items[@i].ProductId" value="@product.ProductId" />
                <label>
                    @product.ProductName
                    (Stock: @product.Stock)
                </label>
            </div>

            <div class="col-3">
                <input type="number"
                       name="Items[@i].Quantity"
                       class="form-control"
                       min="0"
                       max="@product.Stock"
                       placeholder="Qty" />
            </div>
        </div>
    }

    <button class="btn btn-success mt-3">Place Order</button>
</form>