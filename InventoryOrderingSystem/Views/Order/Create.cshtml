@* Views/Order/Create.cshtml *@
@{
    ViewData["Title"] = "Place an Order";
}

<h2>Place a New Order</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="color: green; font-weight: bold; margin-bottom: 15px;">
        @TempData["SuccessMessage"]
    </div>
}

@if (ViewBag.ErrorMessage != null)
{
    <div style="color: red; font-weight: bold; margin-bottom: 15px;">
        @ViewBag.ErrorMessage
    </div>
}

<form asp-action="Create" method="post" style="max-width: 300px;">
    <div style="margin-bottom: 10px;">
        <label for="customerId">Customer ID:</label>
        <input type="number" id="customerId" name="customerId" class="form-control" required />
    </div>

    <div style="margin-bottom: 10px;">
        <label for="productId">Product ID:</label>
        <input type="number" id="productId" name="productId" class="form-control" required />
    </div>

    <div style="margin-bottom: 10px;">
        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" class="form-control" required min="1" />
    </div>

    <button type="submit" class="btn btn-primary">Place Order</button>
</form>